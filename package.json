    "react-animation",
    "stage",
    "4k-video",
    "mp4",
    "ffmpeg",
    "playwright",
    "headless-chromium",
    "frame-accurate",
    "motion-graphics",
    "video-encoder",
    "cli",
    "voiceover",
    "text-to-speech",
    "elevenlabs"
  ],
  "author": "Sohail Bukhari",
  "license": "MIT",
  "homepage": "https://github.com/dawoodtrumboo/claude-video-export#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dawoodtrumboo/claude-video-export.git"
  },
  "bugs": {
    "url": "https://github.com/dawoodtrumboo/claude-video-export/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.mjs",
    "export": "node cli.mjs"
  },
  "dependencies": {
